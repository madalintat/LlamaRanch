{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LlamaRanch",
  "version": "0.4.0",
  "identifier": "com.llamaranch.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "LlamaRanch",
        "width": 384,
        "height": 240,
        "minWidth": 384,
        "maxWidth": 384,
        "minHeight": 80,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "windowEffects": {
          "effects": [
            "hudWindow",
            "acrylic"
          ],
          "radius": 14
        }
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 700,
        "height": 620,
        "minWidth": 700,
        "minHeight": 420,
        "center": true,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "windowEffects": {
          "effects": [
            "hudWindow",
            "acrylic"
          ],
          "radius": 14
        }
      },
      {
        "label": "chat",
        "title": "LlamaRanch Chat",
        "url": "chat.html",
        "width": 1240,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "config",
        "title": "Configure model",
        "url": "config.html",
        "width": 420,
        "height": 440,
        "minWidth": 420,
        "minHeight": 220,
        "center": true,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "windowEffects": {
          "effects": [
            "hudWindow",
            "acrylic"
          ],
          "radius": 16
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/madalintat/LlamaRanch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczOUI1NjI3NkU2QUJGNTUKUldSVnYycHVKMWFiY3hEY2JaYzI5dGhJMFZGVDJuekFsTEpPZFJIY3NHVW9ZZ296cU5PVEVYRzcK"
    }
  }
}
